SQL_SERVER=your-sql-server-hostname
SQL_DATABASE=your-database-name
SQL_USERNAME=your-username
SQL_PASSWORD=your-password
SQL_DRIVER=ODBC Driver 18 for SQL Server
SQL_ENCRYPT=yes
SQL_TRUST_SERVER_CERTIFICATE=no
# Optional: uncomment and update if you need a custom port or extra ODBC options
# SQL_PORT=1433
# SQL_ODBC_EXTRA=App=StreamlitDemo
